# Paths
export PATH=$HOME/bin:/usr/local/bin:/usr/local/sbin:/usr/bin:/bin:/usr/sbin:/sbin
if [[ -x /opt/homebrew/bin/brew ]]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
elif [[ -x /usr/local/bin/brew ]]; then
    eval "$(/usr/local/bin/brew shellenv)"
fi

# Oh My Zsh
export ZSH=$HOME/.zsh
export STARSHIP_CONFIG=~/.starship.toml
export ZOXIDE_CMD_OVERRIDE=cd

zstyle ':omz:update' mode disabled

# Completion and plugin configuration
zstyle ':completion:*' verbose yes
zstyle ':completion:*:descriptions' format '[%d]'
zstyle ':completion:*:options' description yes
zstyle ':completion:*:options' auto-description '%d'
zstyle ':completion:*' menu no

zstyle ':omz:plugins:eza' dirs-first yes
zstyle ':omz:plugins:eza' git-status yes
zstyle ':omz:plugins:eza' icons yes
zstyle ':omz:plugins:ssh-agent' quiet yes

zstyle ':fzf-tab:complete:cd:*' fzf-preview 'eza -1 --color=always $realpath'

export COMPLETION_WAITING_DOTS="false"
export DISABLE_UNTRACKED_FILES_DIRTY="true"
export ZSH_ALIAS_FINDER_AUTOMATIC=true

plugins=(
    history
    dirhistory
    history-substring-search
    fzf
    fzf-tab
    zsh-autosuggestions
    alias-tips
    alias-finder
    extract
    ssh-agent
    git
    git-extras
    gh
    python
    pip
    eza
    zoxide
    gcloud
    httpie
    docker
    docker-compose
    1password
    vscode
    starship
)

case "$(uname)" in
    Darwin)
        plugins+=(macos)
        ;;
    Linux)
        plugins+=(debian)
        ;;
esac

# Prefer native Zsh completions over Homebrew Git's bash-wrapper completions.
# This gives richer Git option descriptions, e.g. `git diff --<Tab>`.
if command -v brew >/dev/null 2>&1; then
    zsh_functions_dir="$(brew --prefix zsh 2>/dev/null)/share/zsh/functions"

    if [[ -d "$zsh_functions_dir" ]]; then
        fpath=(
            "$zsh_functions_dir"
            ${fpath:#"$zsh_functions_dir"}
        )
    fi
fi

source $ZSH/oh-my-zsh.sh

# Post-Oh My Zsh integrations
source /opt/homebrew/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
eval "$(ruff generate-shell-completion zsh)"
eval "$(atuin init zsh)"

# Local machine-specific config
source "${HOME}/.zshrc.local"

# Aliases
alias l='ll'
alias lla='la'
alias lt='eza --tree --group-directories-first'

# Extras
test -e "${HOME}/.iterm2_shell_integration.zsh" && source "${HOME}/.iterm2_shell_integration.zsh"
